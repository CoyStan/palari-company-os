{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palari.local/schemas/company-os/workspace.schema.json",
  "title": "Palari Company OS Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "goals",
    "humans",
    "palaris",
    "sources",
    "work_items",
    "attempts",
    "evidence_runs",
    "review_verdicts",
    "human_decisions",
    "receipts",
    "decisions",
    "outcomes"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "name": { "type": "string", "minLength": 1 },
    "collection_files": { "$ref": "#/$defs/collection_files" },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/goal" } },
    "humans": { "type": "array", "items": { "$ref": "#/$defs/human" } },
    "palaris": { "type": "array", "items": { "$ref": "#/$defs/palari" } },
    "sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
    "workbenches": { "type": "array", "items": { "$ref": "#/$defs/workbench" } },
    "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" } },
    "authority_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/authority_profile" }
    },
    "playbook_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/playbook_source" }
    },
    "integrations": { "type": "array", "items": { "$ref": "#/$defs/integration" } },
    "integration_plans": {
      "type": "array",
      "items": { "$ref": "#/$defs/integration_plan" }
    },
    "integration_outbox": {
      "type": "array",
      "items": { "$ref": "#/$defs/integration_outbox_item" }
    },
    "work_items": { "type": "array", "items": { "$ref": "#/$defs/work_item" } },
    "proposals": { "type": "array", "items": { "$ref": "#/$defs/proposal" } },
    "attempts": { "type": "array", "items": { "$ref": "#/$defs/attempt" } },
    "evidence_runs": { "type": "array", "items": { "$ref": "#/$defs/evidence_run" } },
    "review_verdicts": { "type": "array", "items": { "$ref": "#/$defs/review_verdict" } },
    "human_decisions": { "type": "array", "items": { "$ref": "#/$defs/human_decision" } },
    "acceptance_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/acceptance_record" }
    },
    "receipts": { "type": "array", "items": { "$ref": "#/$defs/receipt" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "outcomes": { "type": "array", "items": { "$ref": "#/$defs/outcome" } }
  },
  "$defs": {
    "string_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "collection_files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goals": { "$ref": "#/$defs/string_list" },
        "humans": { "$ref": "#/$defs/string_list" },
        "palaris": { "$ref": "#/$defs/string_list" },
        "sources": { "$ref": "#/$defs/string_list" },
        "workbenches": { "$ref": "#/$defs/string_list" },
        "capabilities": { "$ref": "#/$defs/string_list" },
        "authority_profiles": { "$ref": "#/$defs/string_list" },
        "playbook_sources": { "$ref": "#/$defs/string_list" },
        "integrations": { "$ref": "#/$defs/string_list" },
        "integration_plans": { "$ref": "#/$defs/string_list" },
        "integration_outbox": { "$ref": "#/$defs/string_list" },
        "work_items": { "$ref": "#/$defs/string_list" },
        "proposals": { "$ref": "#/$defs/string_list" },
        "attempts": { "$ref": "#/$defs/string_list" },
        "evidence_runs": { "$ref": "#/$defs/string_list" },
        "review_verdicts": { "$ref": "#/$defs/string_list" },
        "human_decisions": { "$ref": "#/$defs/string_list" },
        "acceptance_records": { "$ref": "#/$defs/string_list" },
        "receipts": { "$ref": "#/$defs/string_list" },
        "decisions": { "$ref": "#/$defs/string_list" },
        "outcomes": { "$ref": "#/$defs/string_list" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "severity": { "type": "string" },
        "summary": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "owner": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "completed", "closed", "archived"]
        },
        "priority": { "type": "string" },
        "success_criteria": { "$ref": "#/$defs/string_list" },
        "linked_palaris": { "$ref": "#/$defs/string_list" },
        "linked_work": { "$ref": "#/$defs/string_list" },
        "linked_decisions": { "$ref": "#/$defs/string_list" }
      }
    },
    "human": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "aliases": { "$ref": "#/$defs/string_list" },
        "role": { "type": "string" },
        "authority_level": { "type": "string" },
        "approval_capabilities": { "$ref": "#/$defs/string_list" },
        "skills": { "$ref": "#/$defs/string_list" },
        "ownership_areas": { "$ref": "#/$defs/string_list" },
        "availability": { "type": "string" },
        "capacity_signal": { "type": "string" }
      }
    },
    "palari": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "scope": { "type": "string" },
        "allowed_inputs": { "$ref": "#/$defs/string_list" },
        "forbidden_inputs": { "$ref": "#/$defs/string_list" },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "standards": { "$ref": "#/$defs/string_list" },
        "memory_sources": { "$ref": "#/$defs/string_list" },
        "default_worker": { "type": "string" },
        "owner_human": { "type": "string" },
        "linked_goals": { "$ref": "#/$defs/string_list" },
        "active_work": { "$ref": "#/$defs/string_list" },
        "outcomes": { "$ref": "#/$defs/string_list" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": { "type": "string" },
        "provider": { "type": "string" },
        "uri": { "type": "string" },
        "external_id": { "type": "string" },
        "access_mode": { "type": "string" },
        "selected": { "type": "boolean" },
        "owner_human": { "type": "string" },
        "allowed_palaris": { "$ref": "#/$defs/string_list" },
        "data_class": { "type": "string" },
        "authority": { "type": "string" },
        "steward_human": { "type": "string" },
        "freshness_sla": { "type": "string" },
        "redaction_required": { "type": "boolean" },
        "last_seen_revision": { "type": "string" },
        "last_read_at": { "type": "string" }
      }
    },
    "playbook_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "provider": { "type": "string" },
        "uri": { "type": "string" },
        "ref": { "type": "string" },
        "license": { "type": "string" },
        "enabled": { "type": "boolean" },
        "included_playbooks": { "$ref": "#/$defs/string_list" },
        "install_hint": { "type": "string" }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": [
            "repo",
            "external_tool",
            "skill_pack",
            "mcp_adapter",
            "integration",
            "playbook",
            "policy"
          ]
        },
        "provider": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["enabled", "disabled", "review", "deprecated"]
        },
        "owner_human": { "type": "string" },
        "allowed_actions": { "$ref": "#/$defs/string_list" },
        "allowed_palaris": { "$ref": "#/$defs/string_list" },
        "source_ids": { "$ref": "#/$defs/string_list" },
        "risk_level": {
          "type": "string",
          "enum": ["low", "standard", "high", "critical"]
        },
        "policy_ref": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "authority_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["solo-founder", "team-safe", "strict", "custom"]
        },
        "summary": { "type": "string" },
        "require_human_for_risks": { "$ref": "#/$defs/string_list" },
        "minimum_approval_count": { "type": "integer", "minimum": 0 },
        "r5_approval_count": { "type": "integer", "minimum": 0 },
        "required_approval_capability": { "type": "string" },
        "allow_agent_scope_expansion": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "label"],
      "properties": {
        "id": { "type": "string" },
        "provider": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "label": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["notify", "read", "write", "read_write", "webhook", "dry_run"]
        },
        "owner_human": { "type": "string" },
        "enabled": { "type": "boolean" },
        "allowed_events": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "approval_requested",
              "incident_opened",
              "review_requested",
              "work_started",
              "work_completed",
              "work_blocked"
            ]
          }
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["notify", "comment", "create_issue", "update_issue"]
          }
        },
        "secret_ref": { "type": "string" },
        "risk_level": {
          "type": "string",
          "enum": ["low", "standard", "high", "critical"]
        },
        "source_ids": { "$ref": "#/$defs/string_list" },
        "notes": { "type": "string" }
      }
    },
    "integration_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "integration_id", "work_item_id", "event", "action"],
      "properties": {
        "id": { "type": "string" },
        "integration_id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "event": {
          "type": "string",
          "enum": [
            "approval_requested",
            "incident_opened",
            "review_requested",
            "work_completed",
            "work_blocked"
          ]
        },
        "action": {
          "type": "string",
          "enum": ["notify", "comment", "create_issue", "update_issue"]
        },
        "actor": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["planned", "pending-approval", "approved", "rejected", "canceled"]
        },
        "payload_preview": {
          "type": "object",
          "additionalProperties": true
        },
        "source_boundary": {
          "type": "object",
          "additionalProperties": true
        },
        "risk": {
          "type": "string",
          "enum": ["low", "standard", "high", "critical"]
        },
        "approval_required": { "type": "boolean" },
        "timestamp": { "type": "string" },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" },
        "decision_reason": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "integration_outbox_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "plan_id", "integration_id", "work_item_id", "event", "action", "enqueued_by"],
      "properties": {
        "id": { "type": "string" },
        "plan_id": { "type": "string" },
        "integration_id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "event": {
          "type": "string",
          "enum": [
            "approval_requested",
            "incident_opened",
            "review_requested",
            "work_completed",
            "work_blocked"
          ]
        },
        "action": {
          "type": "string",
          "enum": ["notify", "comment", "create_issue", "update_issue"]
        },
        "enqueued_by": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["queued", "canceled", "sent", "failed"]
        },
        "payload_preview": {
          "type": "object",
          "additionalProperties": true
        },
        "source_boundary": {
          "type": "object",
          "additionalProperties": true
        },
        "risk": {
          "type": "string",
          "enum": ["low", "standard", "high", "critical"]
        },
        "timestamp": { "type": "string" },
        "canceled_by": { "type": "string" },
        "canceled_at": { "type": "string" },
        "cancel_reason": { "type": "string" },
        "sent_by": { "type": "string" },
        "sent_at": { "type": "string" },
        "provider_response": {
          "type": "object",
          "additionalProperties": true
        },
        "failed_at": { "type": "string" },
        "failure_reason": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "workbench": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "summary": { "type": "string" },
        "parent_workbench_id": { "type": "string" },
        "goal_ids": { "$ref": "#/$defs/string_list" },
        "palari_ids": { "$ref": "#/$defs/string_list" },
        "human_ids": { "$ref": "#/$defs/string_list" },
        "source_ids": { "$ref": "#/$defs/string_list" },
        "output_target_ids": { "$ref": "#/$defs/string_list" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "completed", "closed", "archived"]
        }
      }
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "goal", "palari"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "palari": { "type": "string" },
        "workbench_id": { "type": "string" },
        "parent_work_item_id": { "type": "string" },
        "dependency_ids": { "$ref": "#/$defs/string_list" },
        "risk": { "type": "string", "enum": ["R1", "R2", "R3", "R4", "R5"] },
        "intensity": { "type": "string", "enum": ["light", "standard", "high"] },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "active",
            "in-review",
            "needs-human",
            "blocked",
            "completed",
            "closed",
            "done",
            "superseded",
            "abandoned"
          ]
        },
        "terminal_reason": { "type": "string" },
        "successor_work_item_id": { "type": "string" },
        "scope": { "type": "string" },
        "allowed_resources": { "$ref": "#/$defs/string_list" },
        "allowed_sources": { "$ref": "#/$defs/string_list" },
        "allowed_actions": { "$ref": "#/$defs/string_list" },
        "output_targets": { "$ref": "#/$defs/string_list" },
        "path_intents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "intent"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "intent": { "type": "string", "enum": ["create", "modify", "delete"] }
            }
          }
        },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "acceptance_target": { "type": "string" },
        "verification_expectations": { "$ref": "#/$defs/string_list" },
        "current_attempt": { "type": "string" },
        "required_approval_count": { "type": "integer", "minimum": 0 },
        "required_approval_capability": { "type": "string" },
        "recommended_playbooks": { "$ref": "#/$defs/string_list" },
        "conflict_targets": { "$ref": "#/$defs/string_list" },
        "parallel_policy": {
          "type": "string",
          "enum": ["independent", "coordinate", "exclusive"]
        },
        "external_provider": { "type": "string" },
        "external_id": { "type": "string" },
        "external_key": { "type": "string" },
        "external_url": { "type": "string" },
        "external_updated_at": { "type": "string" }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "goal", "palari"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "palari": { "type": "string" },
        "proposer": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["proposed", "under-review", "adopted", "rejected", "deferred"]
        },
        "summary": { "type": "string" },
        "scope": { "type": "string" },
        "risk": { "type": "string", "enum": ["R1", "R2", "R3", "R4", "R5"] },
        "intensity": { "type": "string", "enum": ["light", "standard", "high"] },
        "allowed_resources": { "$ref": "#/$defs/string_list" },
        "allowed_sources": { "$ref": "#/$defs/string_list" },
        "allowed_actions": { "$ref": "#/$defs/string_list" },
        "output_targets": { "$ref": "#/$defs/string_list" },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "acceptance_target": { "type": "string" },
        "verification_expectations": { "$ref": "#/$defs/string_list" },
        "recommended_playbooks": { "$ref": "#/$defs/string_list" },
        "conflict_targets": { "$ref": "#/$defs/string_list" },
        "parallel_policy": {
          "type": "string",
          "enum": ["independent", "coordinate", "exclusive"]
        },
        "linked_work": { "type": "string" },
        "decision_id": { "type": "string" },
        "created_at": { "type": "string" },
        "decided_by": { "type": "string" },
        "decided_at": { "type": "string" },
        "reason": { "type": "string" },
        "external_provider": { "type": "string" },
        "external_id": { "type": "string" },
        "external_key": { "type": "string" },
        "external_url": { "type": "string" },
        "external_updated_at": { "type": "string" }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "actor"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "actor": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "complete", "completed", "failed", "blocked"]
        },
        "branch": { "type": "string" },
        "workspace_path": { "type": "string" },
        "base_sha": { "type": "string" },
        "head_sha": { "type": "string" },
        "model_or_worker": { "type": "string" },
        "started_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "output_targets": { "$ref": "#/$defs/string_list" },
        "commits": { "$ref": "#/$defs/string_list" },
        "changed_files": { "$ref": "#/$defs/string_list" },
        "allowed_paths": { "$ref": "#/$defs/string_list" },
        "forbidden_paths": { "$ref": "#/$defs/string_list" },
        "claim_id": { "type": "string" },
        "claim_expires_at": { "type": "string" },
        "cleanliness": { "type": "string" },
        "result": { "type": "string" }
      }
    },
    "evidence_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "attempt_id", "head_sha", "status"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "attempt_id": { "type": "string" },
        "head_sha": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "base_ref": { "type": "string" },
        "commands": { "$ref": "#/$defs/string_list" },
        "artifacts": { "$ref": "#/$defs/string_list" },
        "artifact_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "output_binding_version": { "type": "string" },
        "manifest_hash": { "type": "string" },
        "receipt_hash": { "type": "string" },
        "previous_receipt_hash": { "type": "string" },
        "summary": { "type": "string" },
        "freshness": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "review_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "reviewed_head", "reviewer", "verdict"],
      "allOf": [
        {
          "if": {
            "properties": { "verdict": { "const": "accept-ready" } },
            "required": ["verdict"]
          },
          "then": {
            "required": [
              "binding_version",
              "attempt_id",
              "attempt_hash",
              "evidence_reference",
              "evidence_manifest_hash",
              "receipt_reference",
              "receipt_hash",
              "work_contract_hash",
              "proof_hash"
            ]
          }
        }
      ],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "reviewed_head": { "type": "string" },
        "reviewer": { "type": "string" },
        "binding_version": { "type": "string" },
        "attempt_id": { "type": "string" },
