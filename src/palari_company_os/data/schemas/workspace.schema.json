{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palari.local/schemas/company-os/workspace.schema.json",
  "title": "Palari Company OS Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "goals",
    "humans",
    "palaris",
    "sources",
    "work_items",
    "attempts",
    "evidence_runs",
    "review_verdicts",
    "human_decisions",
    "receipts",
    "decisions",
    "outcomes"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "collection_files": { "$ref": "#/$defs/collection_files" },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/goal" } },
    "humans": { "type": "array", "items": { "$ref": "#/$defs/human" } },
    "palaris": { "type": "array", "items": { "$ref": "#/$defs/palari" } },
    "sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
    "workbenches": { "type": "array", "items": { "$ref": "#/$defs/workbench" } },
    "playbook_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/playbook_source" }
    },
    "integrations": { "type": "array", "items": { "$ref": "#/$defs/integration" } },
    "work_items": { "type": "array", "items": { "$ref": "#/$defs/work_item" } },
    "attempts": { "type": "array", "items": { "$ref": "#/$defs/attempt" } },
    "evidence_runs": { "type": "array", "items": { "$ref": "#/$defs/evidence_run" } },
    "review_verdicts": { "type": "array", "items": { "$ref": "#/$defs/review_verdict" } },
    "human_decisions": { "type": "array", "items": { "$ref": "#/$defs/human_decision" } },
    "receipts": { "type": "array", "items": { "$ref": "#/$defs/receipt" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "outcomes": { "type": "array", "items": { "$ref": "#/$defs/outcome" } }
  },
  "$defs": {
    "string_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "collection_files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goals": { "$ref": "#/$defs/string_list" },
        "humans": { "$ref": "#/$defs/string_list" },
        "palaris": { "$ref": "#/$defs/string_list" },
        "sources": { "$ref": "#/$defs/string_list" },
        "workbenches": { "$ref": "#/$defs/string_list" },
        "playbook_sources": { "$ref": "#/$defs/string_list" },
        "integrations": { "$ref": "#/$defs/string_list" },
        "work_items": { "$ref": "#/$defs/string_list" },
        "attempts": { "$ref": "#/$defs/string_list" },
        "evidence_runs": { "$ref": "#/$defs/string_list" },
        "review_verdicts": { "$ref": "#/$defs/string_list" },
        "human_decisions": { "$ref": "#/$defs/string_list" },
        "receipts": { "$ref": "#/$defs/string_list" },
        "decisions": { "$ref": "#/$defs/string_list" },
        "outcomes": { "$ref": "#/$defs/string_list" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "severity": { "type": "string" },
        "summary": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "owner": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "completed", "closed", "archived"]
        },
        "priority": { "type": "string" },
        "success_criteria": { "$ref": "#/$defs/string_list" },
        "linked_palaris": { "$ref": "#/$defs/string_list" },
        "linked_work": { "$ref": "#/$defs/string_list" },
        "linked_decisions": { "$ref": "#/$defs/string_list" }
      }
    },
    "human": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "aliases": { "$ref": "#/$defs/string_list" },
        "role": { "type": "string" },
        "authority_level": { "type": "string" },
        "approval_capabilities": { "$ref": "#/$defs/string_list" },
        "skills": { "$ref": "#/$defs/string_list" },
        "ownership_areas": { "$ref": "#/$defs/string_list" },
        "availability": { "type": "string" },
        "capacity_signal": { "type": "string" }
      }
    },
    "palari": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "scope": { "type": "string" },
        "allowed_inputs": { "$ref": "#/$defs/string_list" },
        "forbidden_inputs": { "$ref": "#/$defs/string_list" },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "standards": { "$ref": "#/$defs/string_list" },
        "memory_sources": { "$ref": "#/$defs/string_list" },
        "default_worker": { "type": "string" },
        "owner_human": { "type": "string" },
        "linked_goals": { "$ref": "#/$defs/string_list" },
        "active_work": { "$ref": "#/$defs/string_list" },
        "outcomes": { "$ref": "#/$defs/string_list" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": { "type": "string" },
        "provider": { "type": "string" },
        "uri": { "type": "string" },
        "external_id": { "type": "string" },
        "access_mode": { "type": "string" },
        "selected": { "type": "boolean" },
        "owner_human": { "type": "string" },
        "allowed_palaris": { "$ref": "#/$defs/string_list" },
        "last_seen_revision": { "type": "string" },
        "last_read_at": { "type": "string" }
      }
    },
    "playbook_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "provider": { "type": "string" },
        "uri": { "type": "string" },
        "ref": { "type": "string" },
        "license": { "type": "string" },
        "enabled": { "type": "boolean" },
        "included_playbooks": { "$ref": "#/$defs/string_list" },
        "install_hint": { "type": "string" }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "label"],
      "properties": {
        "id": { "type": "string" },
        "provider": { "type": "string", "enum": ["slack", "github", "jira", "email"] },
        "label": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["notify", "read", "write", "read_write", "webhook", "dry_run"]
        },
        "owner_human": { "type": "string" },
        "enabled": { "type": "boolean" },
        "allowed_events": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "approval_requested",
              "incident_opened",
              "review_requested",
              "work_completed",
              "work_blocked"
            ]
          }
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["notify", "comment", "create_issue", "update_issue"]
          }
        },
        "secret_ref": { "type": "string" },
        "risk_level": {
          "type": "string",
          "enum": ["low", "standard", "high", "critical"]
        },
        "source_ids": { "$ref": "#/$defs/string_list" },
        "notes": { "type": "string" }
      }
    },
    "workbench": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "summary": { "type": "string" },
        "parent_workbench_id": { "type": "string" },
        "goal_ids": { "$ref": "#/$defs/string_list" },
        "palari_ids": { "$ref": "#/$defs/string_list" },
        "human_ids": { "$ref": "#/$defs/string_list" },
        "source_ids": { "$ref": "#/$defs/string_list" },
        "output_target_ids": { "$ref": "#/$defs/string_list" },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "completed", "closed", "archived"]
        }
      }
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "goal", "palari"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "palari": { "type": "string" },
        "workbench_id": { "type": "string" },
        "parent_work_item_id": { "type": "string" },
        "dependency_ids": { "$ref": "#/$defs/string_list" },
        "risk": { "type": "string", "enum": ["R1", "R2", "R3", "R4", "R5"] },
        "intensity": { "type": "string", "enum": ["light", "standard", "high"] },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "active",
            "in-review",
            "needs-human",
            "blocked",
            "completed",
            "closed",
            "done"
          ]
        },
        "scope": { "type": "string" },
        "allowed_resources": { "$ref": "#/$defs/string_list" },
        "allowed_sources": { "$ref": "#/$defs/string_list" },
        "allowed_actions": { "$ref": "#/$defs/string_list" },
        "output_targets": { "$ref": "#/$defs/string_list" },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "acceptance_target": { "type": "string" },
        "verification_expectations": { "$ref": "#/$defs/string_list" },
        "current_attempt": { "type": "string" },
        "required_approval_count": { "type": "integer", "minimum": 0 },
        "required_approval_capability": { "type": "string" },
        "recommended_playbooks": { "$ref": "#/$defs/string_list" },
        "conflict_targets": { "$ref": "#/$defs/string_list" },
        "parallel_policy": {
          "type": "string",
          "enum": ["independent", "coordinate", "exclusive"]
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "actor"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "actor": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "complete", "completed", "failed", "blocked"]
        },
        "branch": { "type": "string" },
        "workspace_path": { "type": "string" },
        "model_or_worker": { "type": "string" },
        "started_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "output_targets": { "$ref": "#/$defs/string_list" },
        "commits": { "$ref": "#/$defs/string_list" },
        "changed_files": { "$ref": "#/$defs/string_list" },
        "cleanliness": { "type": "string" },
        "result": { "type": "string" }
      }
    },
    "evidence_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "attempt_id", "head_sha", "status"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "attempt_id": { "type": "string" },
        "head_sha": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "base_ref": { "type": "string" },
        "commands": { "$ref": "#/$defs/string_list" },
        "artifacts": { "$ref": "#/$defs/string_list" },
        "summary": { "type": "string" },
        "freshness": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "review_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "reviewed_head", "reviewer", "verdict"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "reviewed_head": { "type": "string" },
        "reviewer": { "type": "string" },
        "verdict": {
          "type": "string",
          "enum": ["accept-ready", "changes-requested", "needs-human-decision", "blocked"]
        },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "checks_inspected": { "$ref": "#/$defs/string_list" },
        "residual_risks": { "$ref": "#/$defs/string_list" },
        "timestamp": { "type": "string" }
      }
    },
    "human_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "human_id", "reviewed_head", "decision"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "human_id": { "type": "string" },
        "reviewed_head": { "type": "string" },
        "decision": {
          "type": "string",
          "enum": [
            "accepted",
            "approved",
            "rejected",
            "needs-changes",
            "changes-requested",
            "blocked"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "recorded",
            "accepted",
            "approved",
            "rejected",
            "changes-requested",
            "blocked"
          ]
        },
        "acceptance_mode": { "type": "string" },
        "quorum_status": { "type": "string", "enum": ["", "pending", "met", "not-met"] },
        "evidence_reference": { "type": "string" },
        "review_reference": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "attempt_id", "actor"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "attempt_id": { "type": "string" },
        "actor": { "type": "string" },
        "sources_used": { "$ref": "#/$defs/string_list" },
        "actions_taken": { "$ref": "#/$defs/string_list" },
        "outputs_created": { "$ref": "#/$defs/string_list" },
        "external_writes": { "$ref": "#/$defs/string_list" },
        "not_done": { "$ref": "#/$defs/string_list" },
        "undo_refs": { "$ref": "#/$defs/string_list" },
        "timestamp": { "type": "string" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question"],
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["open", "decided", "answered", "closed", "blocked"]
        },
        "context": { "type": "string" },
        "options": { "$ref": "#/$defs/string_list" },
        "tradeoffs": { "$ref": "#/$defs/string_list" },
        "recommendation": { "type": "string" },
        "safe_default": { "type": "string" },
        "required_human": { "type": "string" },
        "required_role": { "type": "string" },
        "due_date": { "type": "string" },
        "linked_goal": { "type": "string" },
        "linked_work": { "type": "string" },
        "linked_palari": { "type": "string" },
        "result": { "type": "string" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_id", "summary"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string", "enum": ["captured", "completed", "closed"] },
        "what_happened": { "type": "string" },
        "what_changed": { "type": "string" },
        "useful": { "$ref": "#/$defs/string_list" },
        "failed": { "$ref": "#/$defs/string_list" },
        "follow_up_needed": { "$ref": "#/$defs/string_list" },
        "model_worker_notes": { "$ref": "#/$defs/string_list" },
        "timestamp": { "type": "string" }
      }
    }
  }
}
